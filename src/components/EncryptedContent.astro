---
// 从 Astro 的 props 中获取传入的文章标识符和加密后的内容
const { slug, encryptedContent } = Astro.props;
// 从 Vercel 的环境变量中获取预设的密码
const blogPassword = import.meta.env.BLOG_PASSWORD;
---

{
  blogPassword ? (
    <div id={`encrypted-content-${slug}`} data-password={blogPassword}>
      {encryptedContent}
    </div>
  ) : (
    <p>此内容需要密码保护。</p>
  )
}

<script>
  // 这个脚本在浏览器中执行
  import CryptoJS from 'crypto-js';

  function decryptContent(encryptedData, password) {
    try {
      // 使用 CryptoJS 进行 AES 解密
      const decrypted = CryptoJS.AES.decrypt(encryptedData, password);
      // 将解密后的内容转换为 UTF-8 字符串
      return decrypted.toString(CryptoJS.enc.Utf8);
    } catch (error) {
      console.error('解密失败:', error);
      return null;
    }
  }

  function initEncryption() {
    // 获取所有需要加密保护的容器
    const containers = document.querySelectorAll('[id^="encrypted-content-"]');
    
    containers.forEach(container => {
      const storedPassword = container.dataset.password;
      // 弹出输入框让用户输入密码
      const userPassword = prompt('请输入密码以查看加密内容：');
      
      if (userPassword === storedPassword) {
        // 密码正确：获取加密后的内容并解密
        const encryptedHtml = container.innerText; // 这里假设 encryptedContent 是纯文本
        const decryptedHtml = decryptContent(encryptedHtml, userPassword);
        
        if (decryptedHtml) {
          // 将解密后的 HTML 内容设置回容器
          container.innerHTML = decryptedHtml;
          // 移除密码验证相关的属性
          container.removeAttribute('data-password');
        } else {
          container.innerHTML = '<p style="color: red;">解密失败，请检查密码或联系网站管理员。</p>';
        }
      } else {
        // 密码错误：显示错误信息并保留密码输入框
        container.innerHTML = `
          <div style="border: 1px solid #ccc; padding: 20px; text-align: center;">
            <p>密码错误，无法访问加密内容。</p>
            <button onclick="location.reload()">重新尝试</button>
          </div>
        `;
      }
    });
  }

  // 确保 DOM 加载完成后执行
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initEncryption);
  } else {
    initEncryption();
  }
</script>
